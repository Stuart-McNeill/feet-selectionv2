<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Clinical 3D Foot Analysis Pro</title>
<meta name="viewport" content="width=device-width,initial-scale=1">
<style>
    body { margin: 0; background: #050505; color: #eee; font-family: 'Inter', -apple-system, sans-serif; overflow: hidden; }
    #ui { position: fixed; top: 15px; left: 15px; z-index: 100; display: flex; flex-direction: column; gap: 8px; width: 260px; background: rgba(15,15,15,0.95); padding: 18px; border-radius: 12px; border: 1px solid #333; box-shadow: 0 10px 40px rgba(0,0,0,0.6); backdrop-filter: blur(5px); max-height: 90vh; overflow-y: auto; }
    .label { font-size: 10px; color: #888; text-transform: uppercase; letter-spacing: 1.2px; margin: 8px 0 4px 0; }
    .group { display: flex; gap: 4px; }
    button { background: #2a2a2a; color: white; border: 1px solid #444; padding: 10px; border-radius: 6px; cursor: pointer; font-size: 11px; flex: 1; transition: 0.2s; font-weight: 500; }
    button:hover { background: #3a3a3a; border-color: #555; }
    button.active { background: #388e3c; border-color: #4caf50; box-shadow: 0 0 10px rgba(76, 175, 80, 0.3); }
    input { background: #111; border: 1px solid #444; color: white; padding: 10px; border-radius: 6px; font-size: 12px; width: calc(100% - 22px); margin-bottom: 6px; outline: none; }
    #status { position: fixed; top: 15px; right: 15px; background: #2e7d32; color: white; padding: 6px 14px; border-radius: 20px; font-size: 11px; font-weight: bold; border: 1px solid #4caf50; pointer-events: none; }
    #coords { position: fixed; bottom: 15px; left: 15px; background: rgba(0,0,0,0.85); padding: 8px 12px; border-radius: 6px; font-size: 11px; font-family: 'Courier New', monospace; border: 1px solid #333; color: #4caf50; pointer-events: none; }
    hr { border: 0; border-top: 1px solid #333; margin: 10px 0; }
    #edit-panel { display: none; background: #1a1a1a; padding: 12px; border-radius: 8px; margin-top: 5px; border: 1px solid #333; }
    .danger-btn { background: #b71c1c; border-color: #d32f2f; }
</style>

<script type="importmap">
{
    "imports": {
        "three": "https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js",
        "three/examples/jsm/": "https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/"
    }
}
</script>
</head>
<body>

<div id="ui">
    <div class="label">Foot Selection</div>
    <div class="group">
        <button id="leftBtn" class="active">Left Foot</button>
        <button id="rightBtn">Right Foot</button>
    </div>

    <div class="label">Navigation Mode</div>
    <div class="group">
        <button id="rotateBtn" class="active">Rotate View</button>
        <button id="drawBtn">Draw Marker</button>
    </div>

    <div class="label">Marker Actions</div>
    <div class="group">
        <button id="undoBtn">Undo Last</button>
        <button id="clearMarkersBtn">Clear Markers</button>
    </div>

    <hr>
    <button id="toggleEditBtn" style="background:#1565c0; border-color:#1976d2;">Manage Regions</button>
    
    <div id="edit-panel">
        <input type="text" id="regionNameInput" placeholder="Region Name (e.g. Heel)">
        <button id="addRegionBtn" style="background:#0288d1; width:100%;">Create Box</button>
        <button id="exportMapBtn" style="background:#6a1b9a; width:100%; margin-top:8px;">Download Region Map</button>
        <div style="font-size: 9px; color: #777; margin-top: 10px; text-align: center;">
            T: Move | R: Rotate | S: Resize
        </div>
    </div>

    <hr>
    <div class="label">Final Report</div>
    <button id="downloadBtn" style="background:#2e7d32; width:100%; margin-bottom:5px;">Download Report</button>
    <button id="clearBtn" class="danger-btn" style="width:100%;">Reset Everything</button>
</div>

<div id="status">Ready</div>
<div id="coords">Select a mode to begin...</div>

<script type="module">
import * as THREE from "three";
import { GLTFLoader } from "three/examples/jsm/loaders/GLTFLoader.js";
import { OrbitControls } from "three/examples/jsm/controls/OrbitControls.js";
import { TransformControls } from "three/examples/jsm/controls/TransformControls.js";

// --- PRESET REGIONS ---
const PRESET_REGIONS = [
  { name: "Left foot - Dorsal Hallux Toenail", pos: [-0.09020, 0.06905, 0.47595], rot: [0.00000, 0.17125, 0.00000], scale: [0.04911, 0.01155, 0.05000] },
  { name: "Left foot - Dorsal 1st Interphalangeal joint", pos: [-0.09714, 0.07657, 0.43621], rot: [0.00000, 0.17070, 0.00000], scale: [0.06834, 0.01107, 0.02876] },
  { name: "Left foot - Dorsal 2nd Toenail", pos: [-0.02271, 0.05146, 0.47430], rot: [0.23779, 0.15617, 0.00000], scale: [0.03294, 0.00838, 0.03062] },
  { name: "Left foot - Hallux Apex", pos: [-0.09396, 0.04696, 0.49629], rot: [0.48859, -0.03339, 0.00000], scale: [0.06391, 0.04177, 0.01031] },
  { name: "Left foot - Plantar 1st Interphalangeal joint", pos: [-0.09782, 0.01555, 0.43840], rot: [0.00000, 0.00000, 0.00000], scale: [0.07623, 0.01328, 0.02011] },
  { name: "Left foot - Plantar Hallux", pos: [-0.09815, 0.02517, 0.43090], rot: [0.00000, 0.00000, 0.00000], scale: [0.07906, 0.01401, 0.11221] },
  { name: "Left foot - Medial Hallux", pos: [-0.12798, 0.04421, 0.43439], rot: [0.00000, 0.13763, 0.00000], scale: [0.01999, 0.05000, 0.10910] },
  { name: "Left foot - Medial 1st Interphalangeal joint", pos: [-0.13073, 0.04857, 0.43532], rot: [0.00000, 0.00000, 0.00000], scale: [0.01515, 0.03609, 0.01622] },
  { name: "Left foot - Dorsal Hallux", pos: [-0.09700, 0.08231, 0.43952], rot: [0.00452, 0.06786, 0.00795], scale: [0.08033, 0.03004, 0.12294] },
  { name: "Left foot - Dorsal 1st Metatarsophalangeal joint", pos: [-0.10335, 0.09257, 0.34182], rot: [0.00408, 0.06885, 0.03352], scale: [0.08537, 0.04045, 0.07605] },
  { name: "Left foot - Lateral Hallux", pos: [-0.06390, 0.04690, 0.42823], rot: [0.00101, 0.12646, -0.01004], scale: [0.01303, 0.05000, 0.11723] },
  { name: "Left foot - Medial 1st Metatarsophalangeal joint", pos: [-0.14720, 0.05649, 0.33854], rot: [0.00000, 0.00000, 0.00000], scale: [0.01749, 0.07815, 0.08896] },
  { name: "Left foot - Plantar 1st Metatarsophalangeal joint", pos: [-0.10273, 0.01871, 0.33197], rot: [0.00000, 0.00000, 0.00000], scale: [0.08566, 0.03362, 0.09063] },
  { name: "Left foot - Plantar Tibial Sesamoid", pos: [-0.12731, 0.00969, 0.31109], rot: [-0.14882, -0.00762, -0.01836], scale: [0.02550, 0.01192, 0.03249] },
];

const urls = {
    left: "https://stuart-mcneill.github.io/3Dfootselection/Leftfoot.glb",
    right: "https://stuart-mcneill.github.io/feet-selection/RightFoot.glb"
};

let scene, camera, renderer, controls, transformControls;
let raycaster = new THREE.Raycaster();
let mouse = new THREE.Vector2();

let currentFoot = "left";
let footGroup = new THREE.Group();
let markerGroup = new THREE.Group();
let regionGroup = new THREE.Group();

let isLoaded = false;
let mode = "rotate"; 
let markerLogs = [];

const statusEl = document.getElementById("status");
const coordsEl = document.getElementById("coords");

init();
loadFoot();

function init() {
    scene = new THREE.Scene();
    scene.background = new THREE.Color(0x050505);

    camera = new THREE.PerspectiveCamera(35, window.innerWidth / window.innerHeight, 0.01, 100);
    renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    document.body.appendChild(renderer.domElement);

    controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;

    transformControls = new TransformControls(camera, renderer.domElement);
    transformControls.addEventListener('dragging-changed', (e) => { controls.enabled = !e.value; });
    scene.add(transformControls);

    scene.add(new THREE.HemisphereLight(0xffffff, 0x222222, 3.0));
    const sun = new THREE.DirectionalLight(0xffffff, 1.5);
    sun.position.set(2, 5, 5);
    scene.add(sun);

    scene.add(footGroup);
    scene.add(markerGroup);
    scene.add(regionGroup);

    // UI Bindings
    document.getElementById("leftBtn").onclick = () => { if(currentFoot !== "left") { currentFoot = "left"; loadFoot(); } };
    document.getElementById("rightBtn").onclick = () => { if(currentFoot !== "right") { currentFoot = "right"; loadFoot(); } };
    document.getElementById("rotateBtn").onclick = () => setMode("rotate");
    document.getElementById("drawBtn").onclick = () => setMode("draw");
    document.getElementById("undoBtn").onclick = undoLastMarker;
    document.getElementById("clearMarkersBtn").onclick = () => { markerGroup.clear(); markerLogs = []; };
    document.getElementById("exportMapBtn").onclick = exportRegionMap;
    document.getElementById("toggleEditBtn").onclick = () => {
        const p = document.getElementById("edit-panel");
        p.style.display = (p.style.display === "none" || p.style.display === "") ? "block" : "none";
        setMode(p.style.display === "block" ? "edit" : "rotate");
    };
    document.getElementById("addRegionBtn").onclick = () => addRegion();
    document.getElementById("clearBtn").onclick = () => { if(confirm("Wipe all?")) location.reload(); };
    document.getElementById("downloadBtn").onclick = downloadReport;

    window.addEventListener("resize", onResize);
    renderer.domElement.addEventListener("mousedown", onMouseDown);
    window.addEventListener('keydown', (e) => {
        if (e.key.toLowerCase() === 't') transformControls.setMode("translate");
        if (e.key.toLowerCase() === 'r') transformControls.setMode("rotate");
        if (e.key.toLowerCase() === 's') transformControls.setMode("scale");
    });

    animate();
}

function setMode(m) {
    mode = m;
    document.querySelectorAll(".group button, #toggleEditBtn").forEach(b => b.classList.remove("active"));
    const btn = document.getElementById(m + "Btn") || document.getElementById("toggleEditBtn");
    if(btn) btn.classList.add("active");
    controls.enableRotate = (mode === "rotate");
    if (mode !== "edit") transformControls.detach();
}

function loadFoot() {
    isLoaded = false;
    statusEl.textContent = "Switching...";
    
    // Clear Markers and Foot
    footGroup.clear();
    markerGroup.clear();
    regionGroup.clear();
    markerLogs = [];
    transformControls.detach();

    // Reload relevant boxes for this side
    const sidePrefix = currentFoot === "left" ? "Left" : "Right";
    PRESET_REGIONS.forEach(data => {
        if (data.name.startsWith(sidePrefix)) {
            addRegion(data.name, data.pos, data.rot, data.scale);
        }
    });

    new GLTFLoader().load(urls[currentFoot], (gltf) => {
        const model = gltf.scene;
        model.traverse(c => { if(c.isMesh) c.material = new THREE.MeshStandardMaterial({ color: 0xdddddd }); });
        
        // --- NORMALIZATION: ENSURE MODELS ARE SAME SIZE/CENTER ---
        const box = new THREE.Box3().setFromObject(model);
        const center = box.getCenter(new THREE.Vector3());
        model.position.sub(center); // Re-center the model points
        
        footGroup.add(model);
        
        // Recalculate camera based on fresh normalized box
        const normBox = new THREE.Box3().setFromObject(footGroup);
        const size = normBox.getSize(new THREE.Vector3());
        let cameraDist = Math.abs(Math.max(size.x, size.y, size.z) / 2 / Math.tan((camera.fov * Math.PI / 180) / 2)) * 1.5;
        
        camera.position.set(0, size.y * 0.2, cameraDist);
        controls.target.set(0, 0, 0);
        
        document.getElementById("leftBtn").classList.toggle("active", currentFoot === "left");
        document.getElementById("rightBtn").classList.toggle("active", currentFoot === "right");
        
        statusEl.textContent = "READY: " + currentFoot.toUpperCase();
        isLoaded = true;
    });
}

function addRegion(name, pos, rot, scale) {
    const rName = name || document.getElementById("regionNameInput").value || "New Region";
    const mesh = new THREE.Mesh(
        new THREE.BoxGeometry(1, 1, 1),
        new THREE.MeshBasicMaterial({ color: 0x00f2ff, wireframe: true, transparent: true, opacity: 0.6 })
    );
    
    if (pos) {
        mesh.position.set(...pos);
        mesh.rotation.set(...rot);
        mesh.scale.set(...scale);
    } else {
        mesh.position.copy(controls.target);
        mesh.scale.set(0.05, 0.05, 0.05);
    }
    
    mesh.userData.name = rName;
    regionGroup.add(mesh);
    if (!pos) transformControls.attach(mesh);
}

function onMouseDown(e) {
    if (!isLoaded || e.button !== 0) return;
    mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
    mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
    raycaster.setFromCamera(mouse, camera);

    if (mode === "edit") {
        const hits = raycaster.intersectObjects(regionGroup.children);
        if (hits.length > 0) transformControls.attach(hits[0].object);
    } else if (mode === "draw") {
        const hits = raycaster.intersectObject(footGroup, true);
        if (hits.length > 0) {
            const pos = hits[0].point;
            let region = "Undefined Area";
            
            regionGroup.children.forEach(box => {
                const localPoint = box.worldToLocal(pos.clone());
                if (Math.abs(localPoint.x) < 0.5 && Math.abs(localPoint.y) < 0.5 && Math.abs(localPoint.z) < 0.5) {
                    region = box.userData.name;
                }
            });

            const marker = new THREE.Mesh(new THREE.SphereGeometry(0.003), new THREE.MeshBasicMaterial({ color: 0xff4400 }));
            marker.position.copy(pos);
            markerGroup.add(marker);
            markerLogs.push({ x: pos.x.toFixed(4), y: pos.y.toFixed(4), z: pos.z.toFixed(4), region });
            coordsEl.textContent = `Point: ${region}`;
        }
    }
}

function exportRegionMap() {
    let output = "const PRESET_REGIONS = [\n";
    regionGroup.children.forEach(box => {
        const p = box.position, r = box.rotation, s = box.scale;
        output += `  { name: "${box.userData.name}", pos: [${p.x.toFixed(5)}, ${p.y.toFixed(5)}, ${p.z.toFixed(5)}], rot: [${r.x.toFixed(5)}, ${r.y.toFixed(5)}, ${r.z.toFixed(5)}], scale: [${s.x.toFixed(5)}, ${s.y.toFixed(5)}, ${s.z.toFixed(5)}] },\n`;
    });
    output += "];";
    const blob = new Blob([output], { type: "text/javascript" });
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = "region_map.js";
    a.click();
}

function undoLastMarker() {
    if (markerGroup.children.length > 0) {
        markerGroup.remove(markerGroup.children[markerGroup.children.length - 1]);
        markerLogs.pop();
    }
}

function downloadReport() {
    let txt = `FOOT ANALYSIS (${currentFoot.toUpperCase()})\n\n`;
    markerLogs.forEach((l, i) => txt += `${i+1}. [${l.region}] X:${l.x} Y:${l.y} Z:${l.z}\n`);
    const blob = new Blob([txt], { type: "text/plain" });
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = `Report_${currentFoot}.txt`;
    a.click();
}

function onResize() {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
}

function animate() {
    requestAnimationFrame(animate);
    controls.update();
    renderer.render(scene, camera);
}
</script>
</body>
</html>